APP_ENV=local
PUBLIC_BASE_URL=https://api.example.com
TRUST_PROXY_HEADERS=false
TRUSTED_PROXIES=127.0.0.1/32,::1/128

DATABASE_URL=postgresql+asyncpg://ozon_commerce:change-me@127.0.0.1:5432/ozon_commerce
REDIS_URL=redis://127.0.0.1:6379/0

JWT_SECRET=replace-with-long-random-secret
API_KEY_HASH_SECRET=replace-with-different-long-random-secret
INTERNAL_ADAPTER_TOKEN=replace-with-internal-token

IMAGE_ADAPTER_BASE_URL=http://127.0.0.1:8088
IMAGE_ADAPTER_UPLOAD_PATH=/ozon-upload
IMAGE_ADAPTER_UPLOAD_TOKEN=replace-with-upload-token
IMAGE_GENERATION_ENDPOINT=
FULFILLMENT_ADAPTER_BASE_URL=
PAYMENT_WEBHOOK_SECRET=
REQUIRE_REALNAME_FOR_API_KEYS=false
REQUIRE_REALNAME_FOR_CLIENT_RUNS=false
AUDIT_INCLUDE_EMAIL_HINT=false
BCRYPT_ROUNDS=12
ENFORCE_JTI=true

DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change-me-now
